{
  "name": "portal-operativo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Vita Delta - Portal Operativo Interno (frontend TEST, sub-slice 0)",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "qa": "vite --config vite.qa.config.ts",
    "qa:build": "vite build --config vite.qa.config.ts --outDir ../dist-qa --emptyOutDir",
    "qa:probes": "node qa/run-probes.mjs",
    "qa:responsive": "node qa/responsive.mjs",
    "qa:higiene": "node qa/higiene.mjs",
    "typecheck:qa": "tsc --noEmit -p tsconfig.qa.json",
    "qa:estructural": "node qa/estructural.mjs",
    "qa:mutacion": "node qa/mutacion.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "esbuild": "^0.28.1",
    "playwright": "^1.61.1",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.4.0"
  }
}

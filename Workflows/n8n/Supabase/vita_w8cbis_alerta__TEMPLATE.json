    {
      "parameters": {
        "jsCode": "function envioOk(nodeName) {\n  try {\n    const it = $(nodeName).first();\n    if (!it) return false;\n    if (it.json && it.json.error) return false;\n    return true;\n  } catch (e) { return false; }\n}\nconst ctx = $('Ventana + armar mail').first().json;\nreturn [{\n  json: {\n    id_reserva: ctx.id_reserva, entorno: ctx.entorno, fecha_checkin: ctx.fecha_checkin,\n    operativo: envioOk('Mail operativo') ? 'ok' : 'fail',\n    limpieza: envioOk('Mail limpieza') ? 'ok' : 'fail',\n    aviso: 'Notificacion 8C-bis: el resultado del mail NO afecta la reserva confirmada.',\n  },\n}];"
      },

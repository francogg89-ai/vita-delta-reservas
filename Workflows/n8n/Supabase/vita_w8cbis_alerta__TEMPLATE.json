      "id": "b2bfa53f-154b-45c9-b13a-abea1d42e1d9",
      "name": "Reserva encontrada?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        896,
        192
      ]
    },
    {
      "parameters": {
        "jsCode": "const entorno = $('Validar entrada').first().json.entorno || 'ops';\nconst CFG = {\n  test: {\n    destinatarios: { operativo: ['OPERATIVO_1@EJEMPLO.COM'], limpieza: ['OPERATIVO_1@EJEMPLO.COM'] },\n    url_op: 'https://<TU_INSTANCIA>.app.n8n.cloud/webhook/w8c-op-ops',\n    url_limp: 'https://<TU_INSTANCIA>.app.n8n.cloud/webhook/w8c-limp-ops',\n  },\n  ops: {\n    destinatarios: { operativo: ['OPERATIVO_1@EJEMPLO.COM','OPERATIVO_2@EJEMPLO.COM'], limpieza: ['LIMPIEZA@EJEMPLO.COM'] },\n    url_op: 'https://<TU_INSTANCIA>.app.n8n.cloud/webhook/w8c-op-ops',\n    url_limp: 'https://<TU_INSTANCIA>.app.n8n.cloud/webhook/w8c-limp-ops',\n  },\n};\nconst cfg = CFG[entorno] || CFG.ops;\nfunction ymd(v) {\n  if (v == null) return null;\n  const s = String(v);\n  const m = s.match(/^(\\d{4})-(\\d{2})-(\\d{2})/);\n  return m ? m[0] : null;\n}\nconst row = $input.first().json;\nconst ci = ymd(row.fecha_checkin);\nconst co = ymd(row.fecha_checkout);\nconst hoy = $now.setZone('America/Argentina/Buenos_Aires').toFormat('yyyy-MM-dd');\nconst limite = $now.setZone('America/Argentina/Buenos_Aires').plus({ days: 7 }).toFormat('yyyy-MM-dd');\nconst enVentana = ci != null && ci >= hoy && ci <= limite;\nconst cabana = row.cabana || '';\nconst asunto = '[Vita Delta] Nueva reserva proxima - ' + cabana + ' - ' + (ci || '');\nconst cuerpoBase = 'Se confirmo una reserva proxima.\\n\\n' + 'Cabana: ' + cabana + '\\n' + 'Entrada: ' + (ci || '') + '\\n' + 'Salida: ' + (co || '') + '\\n\\n';\nconst cuerpoOperativo = cuerpoBase + 'Ver calendario operativo:\\n' + cfg.url_op + '\\n';\nconst cuerpoLimpieza = cuerpoBase + 'Ver calendario de limpieza:\\n' + cfg.url_limp + '\\n';\nreturn [{\n  json: {\n    en_ventana: enVentana, hoy, limite, fecha_checkin: ci, fecha_checkout: co, cabana, asunto,\n    cuerpo_operativo: cuerpoOperativo, cuerpo_limpieza: cuerpoLimpieza,\n    dest_operativo: cfg.destinatarios.operativo.join(','), dest_limpieza: cfg.destinatarios.limpieza.join(','),\n    id_reserva: row.id_reserva, entorno,\n  },\n}];"
      },

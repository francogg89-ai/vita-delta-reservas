      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  r.id_reserva,\n  c.nombre AS cabana,\n  r.fecha_checkin,\n  r.fecha_checkout,\n  r.hora_checkin,\n  r.hora_checkout\nFROM reservas r\n  JOIN cabanas c ON c.id_cabana = r.id_cabana\nWHERE r.id_reserva = $1;",
        "options": {
          "queryReplacement": "={{ $json.id_reserva }}"
        }
      },
      "id": "29de22e4-680e-4b92-a771-2b27c2133ada",

      "id": "8f4eef9c-ff46-4861-8976-b93775ab51b1",
      "name": "Disparo 8C-bis",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1.1,
      "position": [
        0,
        288
      ]
    },
    {
      "parameters": {
        "jsCode": "const inItem = $input.first() ? $input.first().json : {};\nconst rawId = inItem.id_reserva;\nconst idReserva = Number(rawId);\nconst idValido = Number.isInteger(idReserva) && idReserva > 0;\nconst entorno = String(inItem.entorno || '').toLowerCase().trim();\nconst entornoValido = entorno === 'test' || entorno === 'ops';\nconst entradaValida = idValido && entornoValido;\nreturn [{\n  json: {\n    entrada_valida: entradaValida,\n    id_reserva: idValido ? idReserva : null,\n    id_pre_reserva: inItem.id_pre_reserva ?? null,\n    entorno: entornoValido ? entorno : null,\n    source: inItem.source ?? null,\n    operador: inItem.operador ?? null,\n    _motivo_invalido: entradaValida ? null : (!idValido ? 'id_reserva ausente o no numerico' : 'entorno invalido'),\n  },\n}];"
      },
      "id": "f33e73aa-c291-4ce0-b435-da3faedc8800",
      "name": "Validar entrada",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
